  "submissionGuide": [
    {
      "order": 1,
      "title": "Access Official ESTA Website",
      "description": "Go to the official US Customs and Border Protection ESTA website. Beware of unofficial sites that charge additional fees.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Only use esta.cbp.dhs.gov - the official site",
        "Avoid third-party sites that charge extra fees",
        "The official fee is $21 per application"
      ]
    },
    {
      "order": 2,
      "title": "Start New Application",
      "description": "Click 'New Application' and then 'Individual Application' to begin your ESTA application.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Choose your preferred language",
        "You have 7 days to complete the application",
        "Keep your confirmation number safe"
      ]
    },
    {
      "order": 3,
      "title": "Enter Applicant Information",
      "description": "Fill in your personal details exactly as they appear on your passport.",
      "fieldsOnThisScreen": ["surname", "firstName", "middleName", "aliases", "dateOfBirth", "cityOfBirth", "countryOfBirth", "gender"],
      "tips": [
        "Names must match passport exactly",
        "Include all given names from passport",
        "Be honest about aliases and other names used"
      ]
    },
    {
      "order": 4,
      "title": "Passport Information",
      "description": "Enter all passport details from your passport's information page.",
      "fieldsOnThisScreen": ["passportNumber", "passportCountry", "passportIssueDate", "passportExpirationDate", "issuingAuthority"],
      "tips": [
        "Passport must be e-passport with chip",
        "Must be valid for duration of stay",
        "Double-check passport number"
      ]
    },
    {
      "order": 5,
      "title": "Contact Information",
      "description": "Provide your current contact information.",
      "fieldsOnThisScreen": ["homeAddress", "homePhone", "workPhone", "email"],
      "tips": [
        "Use email you check regularly",
        "Include country codes for phone numbers",
        "Address should be your permanent residence"
      ]
    },
    {
      "order": 6,
      "title": "Employment Information",
      "description": "Enter your current or most recent employment details.",
      "fieldsOnThisScreen": ["employer", "employerAddress", "employerPhone", "jobTitle"],
      "tips": [
        "If unemployed, enter 'UNEMPLOYED'",
        "Students can enter school name",
        "Retired persons should enter last employer"
      ]
    },
    {
      "order": 7,
      "title": "Emergency Contact",
      "description": "Provide emergency contact information for someone not traveling with you.",
      "fieldsOnThisScreen": ["emergencyContactName", "emergencyContactPhone", "emergencyContactEmail"],
      "tips": [
        "Should be someone in your home country",
        "Cannot be someone traveling with you",
        "Include full international phone number"
      ]
    },
    {
      "order": 8,
      "title": "Travel Information",
      "description": "Enter details about your planned travel to the United States.",
      "fieldsOnThisScreen": ["purposeOfTravel", "addressInUS", "contactPersonUS", "contactPhoneUS"],
      "tips": [
        "Purpose affects your permitted activities",
        "Hotel name and address is acceptable",
        "Contact person can be hotel or tour operator"
      ]
    },
    {
      "order": 9,
      "title": "Eligibility Questions",
      "description": "Answer all security and eligibility questions truthfully. Most travelers will answer 'No' to all questions.",
      "fieldsOnThisScreen": ["mentalDisorder", "drugConviction", "childAbduction", "crimeConviction", "controlledSubstance", "prostitution", "moneyLaundering", "humanTrafficking", "terrorism", "genocide", "childSoldier", "religiousFreedom", "visaRefusal"],
      "tips": [
        "Answer honestly - false answers are grounds for denial",
        "Most legitimate travelers answer 'No' to all",
        "If you answer 'Yes', you may need a visa instead",
        "Review each question carefully"
      ]
    },
    {
      "order": 10,
      "title": "Review Application",
      "description": "Carefully review all information for accuracy before submitting.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Check all names match passport exactly",
        "Verify all dates are correct",
        "Ensure contact information is current",
        "You cannot edit after submission"
      ]
    },
    {
      "order": 11,
      "title": "Submit and Pay",
      "description": "Submit your application and pay the $21 fee by credit card.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Payment is required for processing",
        "Fee is $21 regardless of approval/denial",
        "Save your confirmation number",
        "Processing usually takes minutes to hours"
      ]
    },
    {
      "order": 12,
      "title": "Check Status and Approval",
      "description": "Check your application status using your confirmation number. Print or save your approval.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Approved ESTA is valid for 2 years",
        "Allows multiple entries up to 90 days each",
        "No physical document needed",
        "Airlines and CBP access electronically"
      ]
    }
  ],
