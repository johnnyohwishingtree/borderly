{
  "countryCode": "MYS",
  "countryName": "Malaysia",
  "schemaVersion": "1.0.0",
  "lastUpdated": "2025-06-01T00:00:00Z",
  "portalUrl": "https://imigresen-online.imi.gov.my/mdac/main",
  "portalName": "Malaysia Digital Arrival Card (MDAC)",
  "metadata": {
    "priority": 3,
    "complexity": "medium",
    "popularity": 80,
    "lastVerified": "2025-06-01T00:00:00Z",
    "supportedLanguages": ["en", "ms"],
    "implementationStatus": "complete",
    "maintenanceFrequency": "monthly"
  },
  "changeDetection": {
    "monitoredSelectors": [".mdac-form", ".arrival-form", "#submit-application"],
    "changeThreshold": 15,
    "fallbackActions": [
      {
        "trigger": "mdac_update",
        "action": "notify",
        "message": "Malaysia MDAC system has been updated. Please verify manually."
      }
    ]
  },
  "submission": {
    "earliestBeforeArrival": "3d",
    "latestBeforeArrival": "0h",
    "recommended": "24h"
  },
  "portalFlow": {
    "requiresAccount": false,
    "multiStep": true,
    "canSaveProgress": false,
    "sessionTimeout": "20m",
    "prerequisites": [
      {
        "type": "document",
        "description": "Valid passport",
        "required": true
      }
    ]
  },
  "sections": [
    {
      "id": "personal",
      "title": "Personal Information",
      "fields": [
        {
          "id": "surname",
          "label": "Surname (as on passport)",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.surname",
          "countrySpecific": false,
          "portalFieldName": "Family Name",
          "portalSelector": "input[name='familyName'], #familyName, input[name='surname']"
        },
        {
          "id": "givenNames",
          "label": "Given Names (as on passport)",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.givenNames",
          "countrySpecific": false,
          "portalFieldName": "First Name",
          "portalSelector": "input[name='firstName'], #firstName, input[name='givenName']"
        },
        {
          "id": "dateOfBirth",
          "label": "Date of Birth",
          "type": "date",
          "required": true,
          "autoFillSource": "profile.dateOfBirth",
          "countrySpecific": false,
          "portalFieldName": "Date of Birth",
          "portalSelector": "input[name='dob'], #dob, input[name='dateOfBirth']"
        },
        {
          "id": "nationality",
          "label": "Nationality",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.nationality",
          "countrySpecific": false,
          "portalFieldName": "Nationality",
          "portalSelector": "select[name='nationality'], #nationality, select[name='citizenshipCountry']"
        },
        {
          "id": "passportNumber",
          "label": "Passport Number",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.passportNumber",
          "countrySpecific": false,
          "portalFieldName": "Passport Number",
          "portalSelector": "input[name='passportNo'], #passportNo, input[name='passportNumber']"
        },
        {
          "id": "passportExpiry",
          "label": "Passport Expiry Date",
          "type": "date",
          "required": true,
          "autoFillSource": "profile.passportExpiry",
          "countrySpecific": false,
          "portalFieldName": "Passport Expiry Date",
          "portalSelector": "input[name='passportExpiryDate'], #passportExpiryDate, input[name='passportExpiry']"
        },
        {
          "id": "gender",
          "label": "Gender",
          "type": "select",
          "required": true,
          "autoFillSource": "profile.gender",
          "countrySpecific": false,
          "portalFieldName": "Gender",
          "portalSelector": "select[name='gender'], #gender, select[name='sex']",
          "options": [
            { "value": "M", "label": "Male" },
            { "value": "F", "label": "Female" }
          ]
        },
        {
          "id": "email",
          "label": "Email Address",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.email",
          "countrySpecific": false,
          "portalFieldName": "Email Address",
          "portalSelector": "input[name='email'], input[type='email'], #email",
          "validation": {
            "pattern": "^[^@]+@[^@]+\\.[^@]+$"
          }
        },
        {
          "id": "phoneNumber",
          "label": "Phone Number",
          "type": "text",
          "required": true,
          "autoFillSource": "profile.phoneNumber",
          "countrySpecific": false,
          "portalFieldName": "Phone Number",
          "portalSelector": "input[name='phoneNo'], input[name='phone'], input[type='tel']"
        }
      ]
    },
    {
      "id": "travel",
      "title": "Travel Information",
      "fields": [
        {
          "id": "arrivalDate",
          "label": "Arrival Date",
          "type": "date",
          "required": true,
          "autoFillSource": "leg.arrivalDate",
          "countrySpecific": false,
          "portalFieldName": "Arrival Date",
          "portalSelector": "input[name='arrivalDate'], #arrivalDate, input[name='dateOfArrival']"
        },
        {
          "id": "arrivalAirport",
          "label": "Port of Entry",
          "type": "select",
          "required": true,
          "autoFillSource": "leg.arrivalAirport",
          "countrySpecific": true,
          "portalFieldName": "Port of Entry",
          "portalSelector": "select[name='portOfEntry'], #portOfEntry, select[name='arrivalAirport']",
          "options": [
            { "value": "KUL", "label": "Kuala Lumpur International Airport (KLIA)" },
            { "value": "KUA", "label": "Kuala Lumpur International Airport 2 (KLIA2)" },
            { "value": "PEN", "label": "Penang International Airport" },
            { "value": "JHB", "label": "Johor Bahru Sultan Ismail Airport" },
            { "value": "LGK", "label": "Langkawi International Airport" },
            { "value": "KCH", "label": "Kuching Airport" },
            { "value": "BKI", "label": "Kota Kinabalu International Airport" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "id": "flightNumber",
          "label": "Flight Number",
          "type": "text",
          "required": true,
          "autoFillSource": "leg.flightNumber",
          "countrySpecific": false,
          "portalFieldName": "Flight Number",
          "portalSelector": "input[name='flightNo'], #flightNo, input[name='flightNumber']"
        },
        {
          "id": "purposeOfVisit",
          "label": "Purpose of Visit",
          "type": "select",
          "required": true,
          "countrySpecific": true,
          "portalFieldName": "Purpose of Visit",
          "portalSelector": "select[name='purposeOfVisit'], #purposeOfVisit, select[name='visitPurpose']",
          "options": [
            { "value": "tourism", "label": "Tourism/Holiday" },
            { "value": "business", "label": "Business" },
            { "value": "visiting_family", "label": "Visiting Family/Friends" },
            { "value": "transit", "label": "Transit" },
            { "value": "conference", "label": "Conference/Meeting" },
            { "value": "medical", "label": "Medical Treatment" },
            { "value": "education", "label": "Education" },
            { "value": "other", "label": "Other" }
          ]
        },
        {
          "id": "durationOfStay",
          "label": "Duration of Stay (days)",
          "type": "number",
          "required": true,
          "countrySpecific": false,
          "autoFillSource": "leg._calculatedDuration",
          "portalFieldName": "Duration of Stay (Days)",
          "portalSelector": "input[name='stayDuration'], #stayDuration, input[name='durationOfStay']",
          "validation": {
            "min": 1,
            "max": 90
          },
          "helpText": "Maximum 90 days for tourism"
        }
      ]
    },
    {
      "id": "accommodation",
      "title": "Accommodation in Malaysia",
      "fields": [
        {
          "id": "hotelName",
          "label": "Hotel / Accommodation Name",
          "type": "text",
          "required": true,
          "autoFillSource": "leg.accommodation.name",
          "countrySpecific": false,
          "portalFieldName": "Name of Accommodation",
          "portalSelector": "input[name='hotelName'], #hotelName, input[name='accommodationName']"
        },
        {
          "id": "hotelAddress",
          "label": "Address of Accommodation",
          "type": "textarea",
          "required": true,
          "autoFillSource": "leg.accommodation.address._formatted",
          "countrySpecific": false,
          "portalFieldName": "Address of Accommodation",
          "portalSelector": "textarea[name='hotelAddress'], #hotelAddress, textarea[name='accommodationAddress']"
        },
        {
          "id": "hotelPhone",
          "label": "Phone Number of Accommodation",
          "type": "text",
          "required": false,
          "autoFillSource": "leg.accommodation.phone",
          "countrySpecific": false,
          "portalFieldName": "Contact Number of Accommodation",
          "portalSelector": "input[name='hotelContactNo'], #hotelContactNo, input[name='hotelPhone']"
        }
      ]
    },
    {
      "id": "health_declarations",
      "title": "Health and Travel Declarations",
      "fields": [
        {
          "id": "healthCondition",
          "label": "Do you have any infectious diseases or health conditions?",
          "type": "boolean",
          "required": true,
          "countrySpecific": true,
          "portalFieldName": "Health Condition Declaration",
          "portalSelector": "input[name='healthCondition'], #healthCondition, input[name='hasHealthCondition']",
          "helpText": "Include recent illnesses, fever, cough, or any contagious conditions"
        },
        {
          "id": "visitedHighRiskCountries",
          "label": "Have you visited any high-risk countries in the past 14 days?",
          "type": "boolean",
          "required": true,
          "countrySpecific": true,
          "portalFieldName": "Visited High-Risk Countries",
          "portalSelector": "input[name='visitedHighRisk'], #visitedHighRisk, input[name='highRiskCountry']",
          "helpText": "Countries with outbreaks of infectious diseases"
        },
        {
          "id": "carryingCurrency",
          "label": "Are you carrying currency exceeding RM10,000 (or equivalent)?",
          "type": "boolean",
          "required": true,
          "autoFillSource": "profile.defaultDeclarations.carryingCurrency",
          "countrySpecific": false,
          "portalFieldName": "Carrying Currency Exceeding RM10,000",
          "portalSelector": "input[name='carryingCurrency'], #carryingCurrency, input[name='currencyDeclaration']",
          "helpText": "Malaysian Ringgit 10,000 or foreign currency equivalent"
        },
        {
          "id": "carryingProhibitedItems",
          "label": "Are you carrying any prohibited or restricted items?",
          "type": "boolean",
          "required": true,
          "autoFillSource": "profile.defaultDeclarations.carryingProhibitedItems",
          "countrySpecific": false,
          "portalFieldName": "Carrying Prohibited or Restricted Items",
          "portalSelector": "input[name='prohibitedItems'], #prohibitedItems, input[name='carryingProhibited']",
          "helpText": "Drugs, weapons, endangered species products, etc."
        }
      ]
    }
  ],
  "submissionGuide": [
    {
      "order": 1,
      "title": "Access MDAC Portal",
      "description": "Go to the Malaysia Digital Arrival Card website. No account creation is required - you can complete the form directly.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Have your passport and flight details ready",
        "Complete this no more than 3 days before arrival"
      ]
    },
    {
      "order": 2,
      "title": "Enter Personal Information",
      "description": "Fill in your passport details exactly as shown on your passport document.",
      "fieldsOnThisScreen": ["surname", "givenNames", "dateOfBirth", "nationality", "passportNumber", "passportExpiry", "gender", "email", "phoneNumber"],
      "tips": [
        "Use the same name format as your passport",
        "Ensure email is valid as you'll receive a confirmation",
        "Include country code for phone number (e.g., +1 for US)"
      ]
    },
    {
      "order": 3,
      "title": "Travel Details",
      "description": "Provide your flight and travel information for entry into Malaysia.",
      "fieldsOnThisScreen": ["arrivalDate", "arrivalAirport", "flightNumber", "purposeOfVisit", "durationOfStay"],
      "tips": [
        "Select the correct airport - KLIA and KLIA2 are different",
        "Duration of stay affects your visa validity"
      ]
    },
    {
      "order": 4,
      "title": "Accommodation Information",
      "description": "Enter details of where you will be staying in Malaysia.",
      "fieldsOnThisScreen": ["hotelName", "hotelAddress", "hotelPhone"],
      "tips": [
        "If staying multiple places, provide the first accommodation",
        "Full address including state and postal code is required"
      ]
    },
    {
      "order": 5,
      "title": "Health and Declaration",
      "description": "Answer health screening and customs declaration questions honestly.",
      "fieldsOnThisScreen": ["healthCondition", "visitedHighRiskCountries", "carryingCurrency", "carryingProhibitedItems"],
      "tips": [
        "False declarations can result in serious legal consequences",
        "If you have medical conditions, bring supporting documentation"
      ]
    },
    {
      "order": 6,
      "title": "Submit and Save",
      "description": "Review all information, submit the form, and save your confirmation details.",
      "fieldsOnThisScreen": [],
      "tips": [
        "Take a screenshot of your submission confirmation",
        "Check your email for the confirmation receipt",
        "Present your confirmation at immigration upon arrival"
      ]
    }
  ]
}
