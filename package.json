{
  "name": "borderly",
  "version": "0.1.0",
  "private": true,
  "description": "Universal travel declaration app",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "web": "npx webpack serve --config webpack.config.js --port 3000 --open",
    "e2e:build": "npx webpack --config webpack.config.js",
    "e2e:test": "npx playwright test",
    "e2e": "npx webpack --config webpack.config.js && npx playwright test",
    "bundle-size": "node scripts/measure-bundle-size.js",
    "bundle-size:ios": "node scripts/measure-bundle-size.js ios",
    "bundle-size:android": "node scripts/measure-bundle-size.js android",
    "bundle-size:compare": "node scripts/measure-bundle-size.js ios compare",
    "build:analyze": "npm run bundle-size:ios && npm run bundle-size:android"
  },
